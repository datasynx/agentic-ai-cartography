{
  "name": "@datasynx/agentic-ai-cartography",
  "version": "2.0.0",
  "description": "MCP-first infrastructure & agentic-AI cartography — install once, every AI agent knows your system landscape. Read-only discovery exposed over the Model Context Protocol.",
  "type": "module",
  "sideEffects": false,
  "mcpName": "io.github.datasynx/cartography",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "datasynx-cartography": "./dist/cli.js",
    "cartography-mcp": "./dist/mcp-bin.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "scripts",
    "server.json",
    "README.md",
    "AGENTS.md",
    "LICENSE",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build": "tsup",
    "build:mcpb": "node scripts/build-mcpb.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:llms": "node scripts/build-llms.mjs",
    "docs:tables": "tsx scripts/gen-docs.ts",
    "docs:build": "npm run docs:tables && npm run docs:llms",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "infrastructure",
    "cartography",
    "discovery",
    "topology",
    "ai-agent",
    "agentic-ai",
    "mcp",
    "devops",
    "platform-engineering",
    "mermaid",
    "backstage",
    "cmdb",
    "network-topology",
    "observability",
    "shadow-it"
  ],
  "author": {
    "name": "Datasynx AI",
    "url": "https://github.com/datasynx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datasynx/agentic-ai-cartography.git"
  },
  "homepage": "https://github.com/datasynx/agentic-ai-cartography#readme",
  "bugs": {
    "url": "https://github.com/datasynx/agentic-ai-cartography/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.59",
    "@anthropic-ai/sdk": "^0.78.0",
    "@huggingface/transformers": "^4.2.0",
    "sqlite-vec": "^0.1.9"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@arethetypeswrong/cli": "^0.18.2",
    "ajv": "^8.20.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "@semantic-release/npm": "^12.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "license-checker": "^25.0.1",
    "publint": "^0.3.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  }
}
